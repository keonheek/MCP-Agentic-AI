# Copy relevant values into the root .env file (C:\Users\keonh\Dev\MCP_Agentic_AI\.env)
# M1 reads from that root .env, not this file.
# Synthesis happens via /m1-brief in your Claude Code session. Zero API cost.

# Telegram bot for M1 morning brief
# One bot + one chat ID shared across all fleets.
# Get token from @BotFather. Get chat ID by sending a message to the bot and calling:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
