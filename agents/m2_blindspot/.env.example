# M2 Blindspot Scanner: required environment variables
# Add these to the root .env file (C:\Users\keonh\Dev\MCP_Agentic_AI\.env)
# Synthesis happens via /m2-blindspot in your Claude Code session. Zero API cost.
# WebSearch (for strand queries) runs via Claude Code subscription, not an external API.

# Telegram bot for M2 output
# One bot + one chat ID shared across all fleets.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Drive folder ID for Doc output (hardcoded in m2.py)
# GDRIVE_FOLDER_ID=1PU6EX-ay-gr3B8FeDwyKOac2zpwXynKy
