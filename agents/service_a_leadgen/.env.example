# Service A Lead-Gen Fleet: environment variables
# Copy this file to .env and fill in real values
# DM drafts are generated via /service-a-daily in your Claude Code session. Zero API cost.

# Telegram bot for morning brief
# One bot + one chat ID shared across all fleets.
# Get token from @BotFather. Get chat ID by sending a message to the bot and calling:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
