{
  "geo-audit-pdf": {
    "output_pattern": "projects/geo-agency/reports/*.pdf",
    "generator": "projects/geo-agency/geo_report_pdf.py",
    "regenerate_command": "cd projects/geo-agency && python -c \"import sys,json; sys.stdout.reconfigure(encoding='utf-8'); from geo_report_pdf import generate_pdf; from pathlib import Path; audit=json.loads(Path('team_test_output/audit_output.json').read_text(encoding='utf-8')); evidence=json.loads(Path('team_test_output/evidence_output.json').read_text(encoding='utf-8')); recs=['웹사이트 루트에 llms.txt 파일 생성','Organization + ProfessionalService JSON-LD 스키마 추가','FAQPage 스키마 구현','홈페이지 주요 서비스 페이지에 콘텐츠 보강']; path=generate_pdf(audit=audit,recommendations=recs,before_text=evidence.get('before',''),output_dir=Path('team_test_output')); print('Generated:',path)\"",
    "target_spec": {
      "pages": 2,
      "max_pages": 3,
      "bilingual": true,
      "categories": 5,
      "sections": ["score_hero", "category_breakdown", "before_after", "recommendations", "roadmap"]
    },
    "notes": "2-page target. fpdf2 renderer. Korean font: 맑은고딕. Before text = Perplexity live result. After text = Claude Haiku simulation."
  },
  "geo-case-study": {
    "output_pattern": "projects/geo-agency/deliverables/*.pdf",
    "generator": "projects/geo-agency/case_study_pdf.py",
    "regenerate_command": "cd projects/geo-agency && python case_study_pdf.py",
    "target_spec": {
      "pages": 1,
      "bilingual": true
    }
  },
  "sme-deck": {
    "output_pattern": "projects/sme-diagnostic-ai/output/*.pptx",
    "generator": "projects/sme-diagnostic-ai/output/deck_generator.py",
    "regenerate_command": "cd projects/sme-diagnostic-ai && python output/deck_generator.py",
    "target_spec": {
      "slides": 12,
      "sections": ["title", "exec_summary", "problem_decomp", "hypotheses", "market_intel", "competitive", "gap_analysis", "benchmark_chart", "root_cause", "recommendations", "roadmap", "roi_next_steps"]
    }
  },
  "consulting-deck": {
    "output_pattern": "projects/consulting-emulation/output/*.pptx",
    "generator": "projects/consulting-emulation/output/pptx_generator.py",
    "regenerate_command": "cd projects/consulting-emulation && python output/pptx_generator.py",
    "target_spec": {
      "slides": 5,
      "sections": ["title", "key_findings", "financial_summary", "market_context", "analyst_note"]
    }
  },
  "valuation-xlsx": {
    "output_pattern": "projects/consulting-emulation/output/*.xlsx",
    "generator": "projects/consulting-emulation/output/excel_generator.py",
    "regenerate_command": "cd projects/consulting-emulation && python output/excel_generator.py",
    "target_spec": {
      "sheets": 4,
      "sheet_names": ["Summary", "DCF Model", "Comps (EV-EBITDA)", "Financials"]
    }
  },
  "lead-intel-xlsx": {
    "output_pattern": "projects/lead-intelligence/output/*.xlsx",
    "generator": "projects/lead-intelligence/export.py",
    "regenerate_command": "cd projects/lead-intelligence && python export.py",
    "target_spec": {
      "sheets": 2,
      "sheet_names": ["Rankings", "Outreach"]
    }
  },
  "geo-kit": {
    "output_pattern": "projects/geo-agency/deliverables/*/",
    "generator": "projects/geo-agency/geo_deliverables.py",
    "regenerate_command": "cd projects/geo-agency && python geo_deliverables.py",
    "target_spec": {
      "files": 7,
      "required_files": ["robots.txt", "llms.txt", "organization_schema.json", "faqpage_schema.json", "implementation_checklist.md", "sov_tracking_queries.txt", "implementation_guide.md"]
    }
  }
}
